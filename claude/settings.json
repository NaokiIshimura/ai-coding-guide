{
  "language": "japanese",
  "permissions": {
    "allow": [
      "Bash(cat *)",
      "Bash(claude agents *)",
      "Bash(code *)",
      "Bash(colima *)",
      "Bash(date *)",
      "Bash(find *)",
      "Bash(gh *)",
      "Bash(git *)",
      "Bash(grep *)",
      "Bash(ls *)",
      "Edit",
      "Fetch",
      "MultiEdit",
      "Read",
      "WebFetch(domain:*)",
      "Write",
      "mcp__*"
    ],
    "deny": [
      "Read(/coverage/)"
    ]
  },
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "command -v afplay > /dev/null 2>&1 && afplay ~/ai-coding-guide/sounds/Glass.aiff || true"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "command -v afplay > /dev/null 2>&1 && afplay ~/ai-coding-guide/sounds/Funk.aiff || true"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-readable.sh"
  },
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  }
}